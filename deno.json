{
  "tasks": {
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "prisma:migrate": "prisma migrate deploy --schema=prisma/schema.prisma",
    "seed": "deno run --allow-net --allow-read --allow-env seed.ts",
    "dev": "deno run --watch --allow-net --allow-read server.ts"
  },
  "imports": {
    "$prisma/": "./node_modules/@prisma/client/",
    "xml-js": "https://esm.sh/xml-js@1.6.1"
  }
}