generator client {
  provider = "prisma-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BibleVersion {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  fullName  String
  books     Book[]
  createdAt DateTime @default(now())
}

model Book {
  id          Int      @id @default(autoincrement())
  name        String
  testament   String
  abbr        String?
  order       Int
  versionId   Int
  chapters    Chapter[]
  version     BibleVersion @relation(fields: [versionId], references: [id])
  createdAt   DateTime @default(now())
  @@unique([name, versionId])
}

model Chapter {
  id        Int     @id @default(autoincrement())
  number    Int
  bookId    Int
  verses    Verse[]
  book      Book    @relation(fields: [bookId], references: [id])
  createdAt DateTime @default(now())
  @@unique([number, bookId])
}

model Verse {
  id        Int      @id @default(autoincrement())
  number    Int
  text      String
  chapterId Int
  chapter   Chapter  @relation(fields: [chapterId], references: [id])
  createdAt DateTime @default(now())
  @@unique([number, chapterId])
}
