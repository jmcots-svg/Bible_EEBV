// ============================================
// COMENTARIOS BÍBLICOS
// ============================================

model CommentarySource {
  id             Int      @id @default(autoincrement())
  name           String   @unique
  fullName       String
  author         String
  volumes        Int      @default(1)
  description    String?
  publishedYear  String?
  isPublicDomain Boolean  @default(true)
  createdAt      DateTime @default(now())
  
  entries        CommentaryEntry[]
}

model CommentaryEntry {
  id           Int      @id @default(autoincrement())
  
  sourceId     Int
  source       CommentarySource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  
  language     String   @default("es")   // 👈 Idioma del comentario
  
  bookAbbr     String
  bookOrder    Int
  chapter      Int
  verseStart   Int?
  verseEnd     Int?
  
  title        String?
  content      String
  contentHtml  String?
  
  divId        String?
  sectionType  String?
  volume       Int      @default(1)
  
  createdAt    DateTime @default(now())
  
  @@unique([sourceId, language, divId])
  @@index([sourceId, bookOrder, chapter])
  @@index([sourceId, language, bookAbbr, chapter])
  @@index([bookOrder, chapter, verseStart])
  @@index([language])
}

model BookAbbreviation {
  id        Int    @id @default(autoincrement())
  abbr      String
  osisAbbr  String
  bookOrder Int
  language  String @default("en")
  
  @@unique([abbr, language])
  @@index([abbr])
  @@index([osisAbbr])
}
