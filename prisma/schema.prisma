generator client {
  provider = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"] // Habilita búsquedas avanzadas si usas Postgres
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BibleVersion {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  fullName  String
  books     Book[]
  createdAt DateTime @default(now())
}

model Book {
  id          Int      @id @default(autoincrement())
  name        String
  testament   String
  abbr        String?
  order       Int
  versionId   Int
  chapters    Chapter[]
  version     BibleVersion @relation(fields: [versionId], references: [id])
  createdAt   DateTime @default(now())

  @@unique([name, versionId])
  @@index([versionId]) // Optimiza la carga de libros de una versión
}

model Chapter {
  id        Int     @id @default(autoincrement())
  number    Int
  bookId    Int
  verses    Verse[]
  book      Book    @relation(fields: [bookId], references: [id])
  createdAt DateTime @default(now())

  @@unique([number, bookId])
  @@index([bookId]) // Optimiza la búsqueda de capítulos por libro
}

model Verse {
  id        Int      @id @default(autoincrement())
  number    Int
  text      String
  chapterId Int
  chapter   Chapter  @relation(fields: [chapterId], references: [id])
  createdAt DateTime @default(now())

  @@unique([number, chapterId])
  @@index([chapterId]) // Optimiza la carga de versículos de un capítulo
  // Opcional: Descomenta la siguiente línea si quieres búsquedas de palabras muy rápidas
  // @@index([text(ops: "text_pattern_ops")]) 
}
