generator client {
  provider = "prisma-client-js"
  previewFeatures = ["fullTextSearch"] // Cambiado de fullTextSearchPostgres a fullTextSearch
}


datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BibleVersion {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  fullName  String
  books     Book[]
  createdAt DateTime @default(now())
}

model Book {
  id          Int      @id @default(autoincrement())
  name        String
  testament   String
  abbr        String?
  order       Int?     // <--- AÑADE EL SIGNO DE INTERROGACIÓN AQUÍ
  versionId   Int
  chapters    Chapter[]
  version     BibleVersion @relation(fields: [versionId], references: [id])
  createdAt   DateTime @default(now())

  @@unique([name, versionId])
  @@index([versionId]) 
}

model Chapter {
  id        Int     @id @default(autoincrement())
  number    Int
  bookId    Int
  verses    Verse[]
  book      Book    @relation(fields: [bookId], references: [id])
  createdAt DateTime @default(now())

  // CAMBIAMOS @@unique por @@index para que no falle por datos duplicados
  @@index([number, bookId]) 
  @@index([bookId]) 
}

model Verse {
  id        Int      @id @default(autoincrement())
  number    Int
  text      String
  chapterId Int
  chapter   Chapter  @relation(fields: [chapterId], references: [id])
  createdAt DateTime @default(now())

  // CAMBIAMOS @@unique por @@index también aquí por si acaso
  @@index([number, chapterId])
  @@index([chapterId])
}
